# ============================================
# Truck Management — Environment Variables
# ============================================
# Copy this file to .env and fill in values.
#   cp .env.example .env
# ============================================

# Runtime environment: development | production | testing
FLASK_ENV=production

# Secret key for session signing & CSRF
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Database connection URL
# SQLite (development / single-server):
#   DATABASE_URL=sqlite:///instance/truck_management.db
# PostgreSQL (production):
#   DATABASE_URL=postgresql://user:pass@host:5432/truck_management
DATABASE_URL=sqlite:///instance/truck_management.db

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=WARNING

# Log file path (inside container: /var/log/app/app.log)
LOG_FILE=/var/log/app/app.log

# PostgreSQL pool settings (only used with PostgreSQL)
# DB_POOL_SIZE=5
# DB_POOL_OVERFLOW=10
# DB_POOL_RECYCLE=3600